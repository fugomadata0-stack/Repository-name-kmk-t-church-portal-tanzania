# =============================================================================
# MONOREPO — tofauti kati ya frontend (Vite) na skripti za seva / DB
# =============================================================================
#
# FRONTEND (tovuti ya portal) — tumia TU faili:
#   app-next/.env.example  →  nakili kuwa app-next/.env.local
#   Usiweke SUPABASE_DB_PASSWORD kwenye app-next/.env.local — weka kwenye faili hii (.env.local ya mizizi) tu.
#
# Nenosiri la seva (service role, DB, nk.) LISIWE kwenye frontend wala Git.
# =============================================================================

# --- Mfano wa mazingira ya skripti / uhamishaji (si kwa Vite) ---
# Tumia kwa npm run db:* au seva pekee; usiimport kwenye React.
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=server-only-never-in-browser

# --- `npm run db:push` (migrations zote, bora kuliko SQL Editor) ---
#
# Chaguo 1 (bora): Dashboard → Database → Connection string → URI — nakili kamili
# SUPABASE_DATABASE_URL=postgresql://postgres.PROJECT_REF:***@aws-0-REGION.pooler.supabase.com:5432/postgres
#
# Chaguo 2: nenosiri la Database (si anon key) — LAZIMA weka eneo halisi la mradi (siyo nadhani)
# SUPABASE_DB_PASSWORD=weka_hapa
# SUPABASE_POOLER_REGION=eu-central-1
# SUPABASE_POOLER_PORT=5432
# SUPABASE_DB_DIRECT=1          majaribio: muunganiko wa direct (IPv6)

