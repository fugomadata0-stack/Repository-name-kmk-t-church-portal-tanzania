# Nakili faili hii ? .env.local (haijafuatiliwa na Git).
# Vercel: Weka vigezo hivi katika Project ? Settings ? Environment Variables (Production / Preview).
#
# Gharama: mradi unaweza kuendeshwa kwa Supabase (free tier) + Vercel (free/hobby).
# Sentry ni hiari (tumia tier ya bure au ache DSN tupu).

# Supabase Dashboard ? Project Settings ? API
# URL = Project URL  |  Key = Publishable (preferred) au anon legacy
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_PUBLISHABLE_OR_ANON_KEY
# Realtime (websocket): chaguomsingi ni false — weka true kwa Dashibodi / notifications zisasishe bila reload.
# Supabase Dashboard → Database → Replication / Realtime: hakikisha jedwali zinazohitajika zimeruhusiwa.
VITE_SUPABASE_REALTIME_ENABLED=false

# Hiari: ufuatiliaji wa makosa (weka DSN ya mradi wa Browser kwenye sentry.io; paketi: npm i @sentry/react)
# VITE_SENTRY_DSN=

# AI Assistant (frontend switch tu; hakuna siri hapa)
# AI requests zitapitia Supabase Edge Function (server side)
VITE_AI_ASSISTANT_ENABLED=false
VITE_AI_FUNCTION_NAME=portal-ai-assistant
